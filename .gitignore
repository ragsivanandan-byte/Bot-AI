# Cache HTTP local (régénérable, ne pas versionner)
cache/*.html

# Base d'historique SQLite (données locales, régénérable)
cache/*.sqlite3

# Cache des taux de change (régénérable)
cache/*.json

# Logs de run
logs/*.log

# Environnements virtuels Python
.venv/
venv/
__pycache__/
*.pyc

# OS
.DS_Store
reports/

# Gabarits de mockups (images locales de l'utilisateur ; on garde juste le README)
mockup_templates/*.png
mockup_templates/*.jpg
mockup_templates/*.jpeg
mockup_templates/**/*.png
mockup_templates/**/*.jpg
mockup_templates/**/*.jpeg
