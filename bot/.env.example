# Copie ce fichier en "bot/.env" et remplis tes clés.
# (bot/.env est ignoré par git — tes clés restent privées.)

# --- VOIX : ElevenLabs (obligatoire) -----------------------------------------
# Clé : elevenlabs.io -> Profil -> API Keys
ELEVENLABS_API_KEY=
# Voix par défaut = Brian (autorité/finance). Pour en changer, mets l'ID voulu.
ELEVENLABS_VOICE_ID=nPczCjzI2devNBz1zQrb
# eleven_multilingual_v2 (qualité) ou eleven_turbo_v2_5 (moins cher/plus rapide)
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# --- VISUELS : xAI Grok Imagine (optionnel) ----------------------------------
# Si vide -> le bot lit tes images dans bot/assets/visuals/short<N>/
# Clé : console.x.ai -> API Keys
XAI_API_KEY=
# grok-2-image ($0.07/img, photoréaliste) ou grok-imagine-image ($0.02/img)
XAI_IMAGE_MODEL=grok-2-image
